{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "opencode",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  },
  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "read": true,
    "glob": true,
    "grep": true
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "*.log"]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "share": "manual",
  "mcp": {
    "dash": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/Kapeli/dash-mcp-server.git", "dash-mcp-server"],
      "enabled": true,
      "environment": {
        "DASH_API_PATH": "/Applications/Dash.app"
      }
    }
  }
}